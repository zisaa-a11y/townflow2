# ===== ENVIRONMENT SETTINGS =====
DEBUG=True
DJANGO_SECRET_KEY=replace_with_secure_secret_key
ALLOWED_HOSTS=localhost,127.0.0.1,web
CSRF_TRUSTED_ORIGINS=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_ALL_ORIGINS=True
TIME_ZONE=UTC
LOG_LEVEL=INFO

# ===== DATABASE CONFIGURATION =====
DATABASE_ENGINE=django.db.backends.mysql
MYSQL_ROOT_PASSWORD=replace_root_password
MYSQL_DATABASE=townetrl_townflow2
MYSQL_USER=townetrl_townflow2user
MYSQL_PASSWORD=FHQHG4A3YPHat7y
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_EXTERNAL_PORT=3307
MYSQL_CONN_MAX_AGE=60
MYSQL_SSL_CA=
MYSQL_SSL_CERT=
MYSQL_SSL_KEY=

# ===== CACHE & SESSION SETTINGS =====
CACHE_BACKEND=db
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_EXTERNAL_PORT=6379

# ===== STATIC & MEDIA FILES =====
STATIC_URL=/static/
STATIC_ROOT=/app/static
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# ===== RATE LIMITING =====
THROTTLE_ANON_RATE=60/minute
THROTTLE_USER_RATE=300/minute
THROTTLE_OCR_PROCESSING_RATE=30/minute

# ===== OCR SETTINGS =====
OCR_ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp
OCR_MAX_IMAGE_SIZE_MB=5
OCR_TIMEOUT_SECONDS=12
OCR_TESSERACT_LANG=eng
OCR_TESSERACT_CONFIG=--oem 3 --psm 6
OCR_APPLY_DENOISE=True
OCR_TESSERACT_CMD=

# ===== GEOCODING SETTINGS =====
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org/reverse
NOMINATIM_USER_AGENT=townflow-backend/1.0
NOMINATIM_REFERER=http://localhost
GEOCODING_TIMEOUT_SECONDS=8
GEOCODING_RETRY_TOTAL=2
GEOCODING_RETRY_BACKOFF=0.5
GEOCODING_ACCEPT_LANGUAGE=en

# ===== FILE UPLOAD LIMITS =====
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DATA_UPLOAD_MAX_MEMORY_SIZE=15728640

# ===== JWT TOKEN SETTINGS =====
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=20
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
OTP_EXPIRY_MINUTES=10

# ===== SECURITY SETTINGS =====
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_REFERRER_POLICY=same-origin
USE_X_FORWARDED_HOST=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ===== API DOCUMENTATION =====
API_TITLE=TownFlow API
API_DESCRIPTION=Enterprise backend API for TownFlow
API_VERSION=1.0.0
APP_FRONTEND_BASE_URL=http://localhost:3000

# ===== GUNICORN SETTINGS (VPS) =====
DJANGO_EXTERNAL_PORT=8000
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# ===== LOGGING =====
# For local development, leave empty. For production, use absolute path:
# LOG_FILE_PATH=/var/log/townflow/django.log
LOG_FILE_PATH=

