DEBUG=False
DJANGO_SECRET_KEY=replace_with_long_secure_secret
ALLOWED_HOSTS=api.yourdomain.com,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://api.yourdomain.com,https://yourdomain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
TIME_ZONE=UTC
LOG_LEVEL=INFO

MYSQL_DATABASE=cheap
MYSQL_USER=cheap_user
MYSQL_PASSWORD=replace_with_strong_password
MYSQL_HOST=your-namecheap-mysql-host
MYSQL_PORT=3306
MYSQL_CONN_MAX_AGE=120
MYSQL_SSL_CA=
MYSQL_SSL_CERT=
MYSQL_SSL_KEY=

REDIS_URL=redis://redis:6379/1

STATIC_URL=/static/
STATIC_ROOT=/app/static
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

THROTTLE_ANON_RATE=30/minute
THROTTLE_USER_RATE=200/minute
THROTTLE_OCR_PROCESSING_RATE=20/minute

OCR_ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp
OCR_MAX_IMAGE_SIZE_MB=5
OCR_TIMEOUT_SECONDS=12
OCR_TESSERACT_LANG=eng
OCR_TESSERACT_CONFIG=--oem 3 --psm 6
OCR_APPLY_DENOISE=True
OCR_TESSERACT_CMD=

NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org/reverse
NOMINATIM_USER_AGENT=townflow-backend/1.0
NOMINATIM_REFERER=https://api.yourdomain.com
GEOCODING_TIMEOUT_SECONDS=8
GEOCODING_RETRY_TOTAL=2
GEOCODING_RETRY_BACKOFF=0.5
GEOCODING_ACCEPT_LANGUAGE=en

FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DATA_UPLOAD_MAX_MEMORY_SIZE=15728640

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
OTP_EXPIRY_MINUTES=10

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_REFERRER_POLICY=same-origin
USE_X_FORWARDED_HOST=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

API_TITLE=TownFlow API
API_DESCRIPTION=Enterprise backend API for TownFlow
API_VERSION=1.0.0
APP_FRONTEND_BASE_URL=https://your-frontend-domain.com

DJANGO_EXTERNAL_PORT=8000
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
