# Namecheap Production Environment Configuration
# Copy this to .env and update with your actual values

# ===== PRODUCTION SETTINGS =====
DEBUG=False
DJANGO_SECRET_KEY=your-super-secure-secret-key-change-this-immediately

# ===== DOMAIN & HOSTS =====
# Replace with your actual Namecheap domain
ALLOWED_HOSTS=api.townflow.org,townflow.org,www.townflow.org
CSRF_TRUSTED_ORIGINS=https://api.townflow.org,https://townflow.org,https://www.townflow.org
CORS_ALLOWED_ORIGINS=https://townflow.org,https://www.townflow.org
CORS_ALLOW_ALL_ORIGINS=True

# Frontend URL
APP_FRONTEND_BASE_URL=https://townflow.org

TIME_ZONE=UTC
LOG_LEVEL=WARNING

# ===== DATABASE CONFIGURATION =====
DATABASE_ENGINE=django.db.backends.mysql

# Namecheap cPanel MySQL Database
MYSQL_DATABASE=cpanelprefix_townflow
MYSQL_USER=cpanelprefix_townflowuser
MYSQL_PASSWORD=FHQHG4A3YPHat7y
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_CONN_MAX_AGE=600
MYSQL_SSL_CA=
MYSQL_SSL_CERT=
MYSQL_SSL_KEY=

# ===== CACHE & SESSION CONFIGURATION =====
# Namecheap shared hosting - use database cache instead of Redis
CACHE_BACKEND=db
# For Redis on VPS, change CACHE_BACKEND=redis and set URL:
REDIS_URL=redis://127.0.0.1:6379/1

# ===== FILE UPLOAD SETTINGS =====
STATIC_URL=/static/
STATIC_ROOT=/home/your_cpanel_user/api.townflow.org/static
MEDIA_URL=/media/
MEDIA_ROOT=/home/your_cpanel_user/api.townflow.org/media

# ===== FILE SIZE LIMITS =====
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DATA_UPLOAD_MAX_MEMORY_SIZE=15728640

# ===== RATE LIMITING =====
THROTTLE_ANON_RATE=100/hour
THROTTLE_USER_RATE=500/hour
THROTTLE_OCR_PROCESSING_RATE=20/hour

# ===== OCR SETTINGS =====
OCR_ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp
OCR_MAX_IMAGE_SIZE_MB=5
OCR_TIMEOUT_SECONDS=12
OCR_TESSERACT_LANG=eng
OCR_TESSERACT_CONFIG=--oem 3 --psm 6
OCR_APPLY_DENOISE=True
OCR_TESSERACT_CMD=

# ===== GEOCODING SETTINGS =====
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org/reverse
NOMINATIM_USER_AGENT=townflow-backend/1.0
NOMINATIM_REFERER=https://api.townflow.org
GEOCODING_TIMEOUT_SECONDS=8
GEOCODING_RETRY_TOTAL=2
GEOCODING_RETRY_BACKOFF=0.5
GEOCODING_ACCEPT_LANGUAGE=en

# ===== JWT TOKEN SETTINGS =====
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=20
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
OTP_EXPIRY_MINUTES=10

# ===== SECURITY SETTINGS =====
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
USE_X_FORWARDED_HOST=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# ===== API DOCUMENTATION =====
API_TITLE=TownFlow API
API_DESCRIPTION=Enterprise backend API for TownFlow
API_VERSION=1.0.0

# ===== GUNICORN SETTINGS (for VPS only) =====
DJANGO_EXTERNAL_PORT=8000
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
